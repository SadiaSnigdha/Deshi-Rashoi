# SQLite Configuration
DB_PATH=./food_delivery.db

# JWT Secret for token authentication
JWT_SECRET=your_jwt_secret_key_here

# Bcrypt Salt Rounds
SALT=10

# Server Port
PORT=4000

# Stripe (optional)
STRIPE_API_KEY=sk_test_dummy_key_for_testing
STRIPE_SECRET_KEY=sk_test_dummy_key_for_testing

# Node Environment
NODE_ENV=development
